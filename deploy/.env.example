TZ=Europe/Moscow
IMAGE_TAG=dev
STORAGE_PROVIDER=SeaweedFS
CONFERENCE_PROVIDER=mediasoup

# credentional for dockers networks
INTERNAL_NETWORK_NAME=internal.network
EXTERNAL_NETWORK_NAME=external.network

# application
APPLICATION_TITLE=CollabSphereAPI
APPLICATION_VERSION=0.0.1
APPLICATION_PUBLIC_BASE_URL=http://localhost:8080
APPLICATION_DEBUG=true
APPLICATION_LOG_LEVEL=DEBUG
APPLICATION_ENVIRONMENT=DEV
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8080
APPLICATION_TIMEOUT_READ=3s
APPLICATION_TIMEOUT_WRITE=5s
APPLICATION_TIMEOUT_IDLE=5s

# postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=collabsphere
POSTGRES_SCHEMA=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD_FILE=/run/secrets/dev_password
POSTGRES_DEBUG=true

# auth
AUTH_JWT_SECRET_FILE=/run/secrets/jwt_secret_key
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
AUTH_GUEST_ACCESS_TTL=24h
AUTH_PASSWORD_LOGIN_ENABLED=true
AUTH_LOCAL_SIGNUP_ENABLED=true
AUTH_PLATFORM_BOOTSTRAP_ACCOUNT_IDS=
AUTH_BROWSER_DEFAULT_RETURN_URL=
AUTH_BROWSER_REDIRECT_ORIGINS=
AUTH_BROWSER_TICKET_TTL=1m

# S3 credentional for master
STORAGE_MASTER_HOST_PORT=9333
STORAGE_MASTER_GRPC_HOST_PORT=19333
STORAGE_MASTER_METRICS_HOST_PORT=9324
STORAGE_MASTER_ADDRESS=master:9333

# S3 credentional for volume
STORAGE_VOLUME_HOST_PORT=8081
STORAGE_VOLUME_GRPC_HOST_PORT=18080
STORAGE_VOLUME_METRICS_HOST_PORT=9325
STORAGE_VOLUME_SIZE_LIMIT_MB=30000
STORAGE_VOLUME_INTERNAL_PORT=8080
STORAGE_VOLUME_DATA_VOLUME=storage.volume.data

# S3 credentional for Filer
STORAGE_FILER_HOST_PORT=8888
STORAGE_FILER_GRPC_HOST_PORT=18888
STORAGE_FILER_METRICS_HOST_PORT=9326
STORAGE_FILER_DATA_VOLUME=storage.filer.data
STORAGE_FILER_ADDRESS=filer:8888

# credentional for S3 client config used by the Go app
STORAGE_S3_ENABLED=true
STORAGE_S3_ENDPOINT=http://s3:8333
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:8333
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=collabsphere
STORAGE_S3_ACCESS_KEY_FILE=/run/secrets/s3_access_key
STORAGE_S3_SECRET_KEY_FILE=/run/secrets/s3_secret_key
STORAGE_S3_PATH_STYLE=true
STORAGE_S3_PRESIGN_TTL=15m
STORAGE_S3_DOWNLOAD_TTL=5m

# storage ports
STORAGE_S3_HOST_PORT=8333
STORAGE_S3_METRICS_HOST_PORT=9327

# S3 provider profile
STORAGE_S3_IMAGE_VERSION=4.15
STORAGE_S3_INIT_IMAGE_VERSION=RELEASE.2025-07-21T05-28-08Z

# realtime / integrations
REALTIME_REDIS_ENABLED=false
REALTIME_REDIS_ADDRESS=redis:6379
REALTIME_REDIS_PASSWORD_FILE=/run/secrets/redis_password
REALTIME_REDIS_DB=0
REALTIME_REDIS_CHANNEL_PREFIX=collabsphere:realtime
REALTIME_REDIS_PRESENCE_TTL=30s
REALTIME_REDIS_TYPING_TTL=5s
TRANSCRIPTION_ENABLED=false
TRANSCRIPTION_ENDPOINT=
TRANSCRIPTION_API_KEY_FILE=/run/secrets/transcription_api_key
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_REQUEST_TIMEOUT=10m
TRANSCRIPTION_WORKER_POLL_EVERY=10s
DOCUMENT_ANALYSIS_ENABLED=false
DOCUMENT_ANALYSIS_PROVIDER=generic-http
DOCUMENT_ANALYSIS_MODEL=legal-doc-ocr-v1
DOCUMENT_ANALYSIS_API_KEY_FILE=/run/secrets/document_analysis_api_key
DOCUMENT_ANALYSIS_REQUEST_TIMEOUT=2m
DOCUMENT_ANALYSIS_WORKER_POLL_EVERY=10s

# misc
MIGRATIONS_DIR=/app/migrations

# zitadel / oidc
AUTH_ZITADEL_ENABLED=false
AUTH_ZITADEL_ISSUER_URL=http://auth.localhost:8090
# Set after first ZITADEL start: create an OIDC application in the admin panel and copy its Client ID here
AUTH_ZITADEL_CLIENT_ID=CHANGE_ME_AFTER_ZITADEL_OIDC_APP_CREATE
# Store the issued client secret in deploy/secrets/identity/zitadel_client_secret
AUTH_ZITADEL_CLIENT_SECRET_FILE=/run/secrets/zitadel_client_secret
AUTH_ZITADEL_ADMIN_TOKEN=
AUTH_ZITADEL_ADMIN_TOKEN_FILE=
AUTH_ZITADEL_REDIRECT_URL=http://localhost:8080/api/v1/auth/zitadel/callback
AUTH_ZITADEL_SCOPES=openid profile email
AUTH_ZITADEL_STATE_TTL=15m
AUTH_ZITADEL_NONCE_TTL=15m
AUTH_ZITADEL_HTTP_TIMEOUT=10s
AUTH_ZITADEL_DOCKER_HOST_ALIAS=auth.localhost

# zitadel local deploy
ZITADEL_VERSION=latest
ZITADEL_LOGIN_VERSION=latest
ZITADEL_POSTGRES_IMAGE_VERSION=18.3-bookworm
ZITADEL_DOMAIN=auth.localhost
ZITADEL_EXTERNALPORT=8090
ZITADEL_EXTERNALSECURE=false
ZITADEL_HOST_PORT=8090
ZITADEL_LOGIN_HOST_PORT=3000
ZITADEL_POSTGRES_HOST_PORT=5433
# Local ZITADEL secret files:
# - deploy/secrets/identity/zitadel_master_key
# - deploy/secrets/identity/zitadel_runtime_secrets.yaml
# - deploy/secrets/identity/zitadel_init_steps.yaml
ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_REQUIRED=true
ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_BASEURI=http://auth.localhost:3000/ui/v2/login/
ZITADEL_OIDC_DEFAULTLOGINURLV2=http://auth.localhost:3000/ui/v2/login/login?authRequest=
ZITADEL_OIDC_DEFAULTLOGOUTURLV2=http://auth.localhost:3000/ui/v2/login/logout?post_logout_redirect=
ZITADEL_SAML_DEFAULTLOGINURLV2=http://auth.localhost:3000/ui/v2/login/login?samlRequest=


