TZ=Europe/Moscow
IMAGE_TAG=dev
STORAGE_PROVIDER=garage

# application
APPLICATION_TITLE=CollabSphereAPI
APPLICATION_VERSION=0.0.1
APPLICATION_PUBLIC_BASE_URL=http://localhost:8080
APPLICATION_DEBUG=true
APPLICATION_LOG_LEVEL=DEBUG
APPLICATION_ENVIRONMENT=DEV
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8080
APPLICATION_TIMEOUT_READ=3s
APPLICATION_TIMEOUT_WRITE=5s
APPLICATION_TIMEOUT_IDLE=5s

# postgres
POSTGRES_HOST=infrastructure.postgres
POSTGRES_PORT=5432
POSTGRES_DB=collabsphere
POSTGRES_SCHEMA=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD_FILE=/run/secrets/dev_password
POSTGRES_DEBUG=true

# auth
AUTH_JWT_SECRET_FILE=/run/secrets/jwt_secret
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
AUTH_GUEST_ACCESS_TTL=24h

# conferences
CONFERENCE_PROVIDER=mediasoup


# generic S3 client config used by the Go app
STORAGE_S3_ENABLED=true
STORAGE_S3_ENDPOINT=http://s3:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_FILE=/run/generated/s3/access_key
STORAGE_S3_SECRET_KEY_FILE=/run/generated/s3/secret_key
STORAGE_S3_BUCKET=collabsphere
STORAGE_S3_PATH_STYLE=true
STORAGE_S3_PRESIGN_TTL=15m
STORAGE_S3_DOWNLOAD_TTL=5m

# legacy minio provider profile
STORAGE_S3_IMAGE_VERSION=RELEASE.2025-09-07T16-13-09Z
STORAGE_S3_INIT_IMAGE_VERSION=RELEASE.2025-07-21T05-28-08Z
STORAGE_S3_ROOT_USER=admin
STORAGE_S3_ROOT_USER_FILE=/run/secrets/s3_access_key
STORAGE_S3_ROOT_PASSWORD_FILE=/run/secrets/s3_secret
STORAGE_S3_PORT=9000
STORAGE_S3_CONSOLE_PORT=9001
STORAGE_S3_BROWSER_REDIRECT_URL=http://localhost:9001

# garage provider profile
STORAGE_S3_GARAGE_IMAGE_VERSION=latest
STORAGE_S3_GARAGE_RPC_PORT=3901
STORAGE_S3_GARAGE_ZONE=dc1
STORAGE_S3_GARAGE_CAPACITY=1G
STORAGE_S3_GARAGE_KEY_NAME=collabsphere-app
STORAGE_S3_GARAGE_RPC_SECRET_FILE=/run/secrets/s3_garage_rpc_secret

# legacy jitsi profile
JITSI_ENABLED=false
JITSI_WEB_IMAGE_VERSION=web-1.0.9105-1
JITSI_PROSODY_IMAGE_VERSION=prosody-13.0.4
JITSI_JICOFO_IMAGE_VERSION=jicofo-1.0-1172-1
JITSI_JVB_IMAGE_VERSION=jvb-2.3-272-g0360d0488-1
JITSI_PUBLIC_URL=https://localhost:8443
JITSI_BASE_URL=https://localhost:8443
JITSI_DOMAIN=localhost
JITSI_APP_ID=collabsphere
JITSI_APP_SECRET_FILE=/run/secrets/jitsi_secret
JITSI_ISSUER=collabsphere
JITSI_AUDIENCE=jitsi
JITSI_TOKEN_TTL=2h
JITSI_HTTP_PORT=8000
JITSI_HTTPS_PORT=8443
JITSI_JVB_PORT=10000
JITSI_JVB_ADVERTISE_IPS=127.0.0.1
JITSI_JICOFO_AUTH_PASSWORD_FILE=/run/secrets/jicofo_auth_password
JITSI_JICOFO_COMPONENT_SECRET_FILE=/run/secrets/jicofo_component_secret
JITSI_JVB_AUTH_PASSWORD_FILE=/run/secrets/jvb_auth_password

# realtime / integrations
REALTIME_REDIS_ENABLED=false
REALTIME_REDIS_ADDRESS=redis:6379
REALTIME_REDIS_PASSWORD_FILE=/run/secrets/redis_password
REALTIME_REDIS_DB=0
REALTIME_REDIS_CHANNEL_PREFIX=collabsphere:realtime
REALTIME_REDIS_PRESENCE_TTL=30s
REALTIME_REDIS_TYPING_TTL=5s
TRANSCRIPTION_ENABLED=false
TRANSCRIPTION_ENDPOINT=
TRANSCRIPTION_API_KEY_FILE=/run/secrets/transcription_api_key
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_REQUEST_TIMEOUT=10m
TRANSCRIPTION_WORKER_POLL_EVERY=10s
DOCUMENT_ANALYSIS_ENABLED=false
DOCUMENT_ANALYSIS_ENDPOINT=
DOCUMENT_ANALYSIS_PROVIDER=generic-http
DOCUMENT_ANALYSIS_MODEL=legal-doc-ocr-v1
DOCUMENT_ANALYSIS_API_KEY_FILE=/run/secrets/document_analysis_api_key
DOCUMENT_ANALYSIS_REQUEST_TIMEOUT=2m
DOCUMENT_ANALYSIS_WORKER_POLL_EVERY=10s

# misc
MIGRATIONS_DIR=/app/migrations
