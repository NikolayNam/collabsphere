AUTH_ZITADEL_ENABLED=false
AUTH_ZITADEL_ISSUER_URL=http://auth.localhost:8090
# Set after first ZITADEL start: create an OIDC application in the admin panel and copy its Client ID here
AUTH_ZITADEL_CLIENT_ID=363668301097730051
# Store the issued client secret in deploy/secrets/identity/zitadel_client_secret
AUTH_ZITADEL_CLIENT_SECRET_FILE=/run/secrets/zitadel_client_secret
AUTH_ZITADEL_ADMIN_TOKEN=
AUTH_ZITADEL_ADMIN_TOKEN_FILE=
# To enable the file-based variant, set AUTH_ZITADEL_ADMIN_TOKEN_FILE=/run/secrets/zitadel_admin_token
# and point AUTH_ZITADEL_ADMIN_TOKEN_SOURCE_FILE at a host file that contains only the raw PAT.
AUTH_ZITADEL_ADMIN_TOKEN_SOURCE_FILE=fixtures/zitadel_admin_token.disabled
AUTH_ZITADEL_REDIRECT_URL=http://api.localhost:8080/v1/auth/zitadel/callback
AUTH_ZITADEL_SCOPES=openid profile email
AUTH_ZITADEL_STATE_TTL=15m
AUTH_ZITADEL_NONCE_TTL=15m
AUTH_ZITADEL_HTTP_TIMEOUT=10s
AUTH_ZITADEL_DOCKER_HOST_ALIAS=auth.localhost

# zitadel local deploy
ZITADEL_VERSION=latest
ZITADEL_LOGIN_VERSION=latest
ZITADEL_DOMAIN=auth.localhost
ZITADEL_EXTERNALPORT=8090
ZITADEL_EXTERNALSECURE=false
ZITADEL_HOST_PORT=8090
ZITADEL_POSTGRES_HOST_PORT=5433
# Local ZITADEL secret files:
ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_REQUIRED=true
ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_BASEURI=http://auth.localhost:3000/ui/v2/login/
ZITADEL_OIDC_DEFAULTLOGINURLV2=http://auth.localhost:3000/ui/v2/login/login?authRequest=
ZITADEL_OIDC_DEFAULTLOGOUTURLV2=http://auth.localhost:3000/ui/v2/login/logout?post_logout_redirect=
ZITADEL_SAML_DEFAULTLOGINURLV2=http://auth.localhost:3000/ui/v2/login/login?samlRequest=
