TZ=Europe/Moscow
INTERNAL_NETWORK_NAME=internal.network

# postgres-test
TEST_POSTGRES_HOST=postgres-test
TEST_POSTGRES_PORT=5434
TEST_POSTGRES_DB=collabsphere_test
TEST_POSTGRES_SCHEMA=db
TEST_POSTGRES_USER=postgres
TEST_POSTGRES_PASSWORD_FILE=/run/secrets/test_postgres_password
TEST_POSTGRES_DEBUG=true

# integration tests create ephemeral databases, so the admin DSN should point to
# the built-in `postgres` database instead of TEST_POSTGRES_DB.
# Example:
# export COLLABSPHERE_TEST_POSTGRES_DSN="host=127.0.0.1 port=5434 user=postgres password=$(cat deploy/secrets/postgres/test/db_password) dbname=postgres sslmode=disable"
